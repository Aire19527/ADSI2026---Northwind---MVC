          function addCustomer(parameter){
               $.ajax({
                  url:'@Url.Action("AddCustomers", "Customer")',
                  method:'POST',
                  data:parameter,
                  dataType:'json',
                  success:function(result)
                  {
                      console.log(result);
                      toastMessage('success','Registro creado exitosamente');
                      clearFormCustomer();
                      getrAllCustomer();
                  },
                  error:function(error)
                  {
                      errorHttp(error);
                  }
              });
          }

          function editProduct(id){
              idProductSelected=id;

              loadCmbCategory(listCategory,1);

              // const customer=listCustomer.find(x=>x.customerId==id);
