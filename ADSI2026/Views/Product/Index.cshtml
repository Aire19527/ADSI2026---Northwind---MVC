           function confirmeditProduct(parameter){
               $.ajax({
                  url:'@Url.Action("UpdateCustomers", "Customer")',
                  method:'PUT',
                  data:parameter,
                  dataType:'json',
                  success:function(result)
                  {
                      console.log(result);
                      toastMessage('success','Registro actualizado exitosamente');
                      clearFormCustomer();
                      getrAllCustomer();
                  },
                  error:function(error)
