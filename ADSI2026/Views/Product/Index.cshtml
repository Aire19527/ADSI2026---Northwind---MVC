          function clearFormCustomer(){
              $('#txtId').val('');
              $('#txtCountry').val('');
              $('#txtCompany').val('');
              $('#txtContactName').val('');
              $('#txtPhone').val('');
              $('#modalProduct').modal('hide');
              
               idCategorySelected = 0;
              idSupplierSelected = 0;
              idProductSelected = 0;
          }

          function validateForm(){
             

              if($('#txtId').val()==''){
                  $('#txtId').focus()
                  toastMessage("warning",'El IdCustomer es obligatorio.');
                  return false;
              }

              if($('#txtCountry').val()==''){
                  $('#txtCountry').focus()
                  toastMessage("warning",'El País es obligatorio.');
                  return false;
              }

              if($('#txtCompany').val()==''){
                  $('#txtCompany').focus()
                  toastMessage("warning",'La Empresa es obligatorio.');
                  return false;
              }

             
                if(idCategorySelected==0){
                  $('#cmbCategory').focus();
                  toastMessage("warning",'La categoría es obligatorio.');
                  return false;
              }


              if($('#txtPhone').val()==''){
                  $('#txtPhone').focus()
                  toastMessage("warning",'El Teléfono es obligatorio.');
                  return false;
              }

              return true;
          }

         function openModal(isEdit)
         {
              if(isEdit){
                  $('#idTitleProduct').html('Editar producto');
                  $('#btnModalSave').html('Editar');
              }else{
                  $('#idTitleProduct').html('Crear producto');
                  $('#btnModalSave').html('Crear');
              }

              $('#modalProduct').modal('show');

