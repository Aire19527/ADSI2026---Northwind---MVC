@{
}


<div class="row">
    <div class="col-md-8">
        <h1>Listado Clientes </h1>
    </div>
    <div class="col-md-4">
        <!-- Button trigger modal -->
        <button type="button" class="btn btn-primary float-end" onclick="openModal(false)">
            <i class="fa-solid fa-plus"></i>
            Crear Cliente
        </button>
    </div>
</div>




<div class="row">
    <div class="col-md-12">
        <table class="table" id="tblCustomer">
            <thead class="thead-dark">
                <tr>
                    <th>Id</th>
                    <th>País</th>
                    <th>Empresa</th>
                    <th>Responsable</th>
                    <th>Télefono</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
            </tbody>

        </table>
    </div>
</div>



<!-- Modal -->
<div class="modal fade" id="modalCustomer" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="idTitleCustomer">Crear cliente</h1>
                <button type="button" class="btn-close" onclick="clearFormCustomer()" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <form>
                    <section class="row">
                        <div class="col-md-2">
                            <label class="col-form-label">Id Customer</label>
                            <input type="text" class="form-control" id="txtId" maxlength="5" placeholder="Digita el ID" />
                        </div>
                        <div class="col-md-5">
                            <label class="col-form-label">País</label>
                            <input type="text" class="form-control" id="txtCountry" placeholder="País" />
                        </div>
                        <div class="col-md-5">
                            <label class="col-form-label">Empresa</label>
                            <input type="text" class="form-control" id="txtCompany" placeholder="Empresa" />
                        </div>
                    </section>

                    <section class="row">

                        <div class="col-md-6">
                            <label class="col-form-label">Responsable</label>
                            <input type="text" class="form-control" id="txtContactName" placeholder="Responsable" />
                        </div>
                        <div class="col-md-6">
                            <label class="col-form-label">Teléfono</label>
                            <input type="text" class="form-control" id="txtPhone" placeholder="Teléfono" />
                        </div>
                    </section>
                </form>






            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger" onclick="clearFormCustomer()">Cancelar</button>
                <button id="btnModalSave" type="button" class="btn btn-outline-success" onclick="onSaveCustomer()">Crear</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script type="text/javascript">

        var isEdit=false;
        var listCustomer=[];
         $(document).ready(function ()
         {
             console.log("Hola clase");
             getrAllCustomer();

         });

         function getrAllCustomer(){
             $.ajax({
                 url:'@Url.Action("GetAllCustomers", "Customer")',
                 method:'GET',
                 dataType:'json',
                 success:function(result)
                 {
                     listCustomer=result;
                     loadTable(listCustomer);
                 },
                 error:function(error)
                 {
                     console.error(error);
                 }
             });
         }

         function loadTable(data){
             $('#tblCustomer').DataTable( {
                 data: data,
                 destroy:true,
                 responsitve:true,
                 columns: [
                     { data: 'customerId' },
                     { data: 'country' },
                     { data: 'companyName' },
                     { data: 'contactName' },
                     { data: 'phone' },
                     {
                         data:null,
                         render:function(data)
                         {
                             const id=data.customerId;
                             return `
                                      <button  class="btn btn-warning" onclick = "editCustomer('`+ id + `')" > <i class="fas fa-edit" > </i> Editar</button >
                                     <button class="btn btn-danger" onclick = "deleteCustomer('`+ id + `')" > <i class="far fa-trash-alt" > </i> Eliminar</button >

                             `
                         }
                     }
                 ]
             } );
         }

         function deleteCustomer(customerId)
         {
             alertDelete().then((result)=>{
                 if(result.isConfirmed)
                 {
                     confirmDeleteCustomer(customerId);
                 }else{
                     console.log('No eliminar',customerId);
                 }
             });
         }

         function confirmDeleteCustomer(customerId){
             $.ajax({
                 url:'@Url.Action("DeleteCustomer", "Customer")',
                 method:'DELETE',
                 data:{
                     'customerId':customerId
                 },
                 dataType:'json',
                 success:function(result)
                 {
                     console.log(result);
                     toastMessage('success','Registro eliminado exitosamente');
                     getrAllCustomer();
                 },
                 error:function(error)
                 {
                       errorHttp(error);
                 }
             });
         }

         function clearFormCustomer(){
             $('#txtId').val('');
             $('#txtCountry').val('');
             $('#txtCompany').val('');
             $('#txtContactName').val('');
             $('#txtPhone').val('');
             $('#modalCustomer').modal('hide');
             isEdit=false;
             $('#txtId').attr('disabled',false);
         }

         function validateForm(){
             if($('#txtId').val()==''){
                 $('#txtId').focus()
                 toastMessage("warning",'El IdCustomer es obligatorio.');
                 return false;
             }

             if($('#txtCountry').val()==''){
                 $('#txtCountry').focus()
                 toastMessage("warning",'El País es obligatorio.');
                 return false;
             }

             if($('#txtCompany').val()==''){
                 $('#txtCompany').focus()
                 toastMessage("warning",'La Empresa es obligatorio.');
                 return false;
             }

             if($('#txtContactName').val()==''){
                 $('#txtContactName').focus()
                 toastMessage("warning",'El Responsable es obligatorio.');
                 return false;
             }

             if($('#txtPhone').val()==''){
                 $('#txtPhone').focus()
                 toastMessage("warning",'El Teléfono es obligatorio.');
                 return false;
             }

             return true;
         }

        function openModal(isEdit)
        {
             if(isEdit){
                 $('#idTitleCustomer').html('Editar cliente');
                 $('#btnModalSave').html('Editar');
             }else{
                 $('#idTitleCustomer').html('Crear cliente');
                 $('#btnModalSave').html('Crear');
             }

             $('#modalCustomer').modal('show');

        }
         function onSaveCustomer(){
             if(validateForm()){
                 const idCustomer=$('#txtId').val();
                 const country=$('#txtCountry').val();
                 const company=$('#txtCompany').val();
                 const contactName=$('#txtContactName').val();
                 const phone=$('#txtPhone').val();
                 const customer={
                     'customerId':idCustomer,
                     'country':country,
                     'companyName':company,
                     'contactName':contactName,
                     'phone':phone,
                 };

                 if(isEdit==false){
                     addCustomer(customer);
                 }else{
                     confirmEditCustomer(customer);
                 }
                console.log(customer);

             }
         }

         function addCustomer(parameter){
              $.ajax({
                 url:'@Url.Action("AddCustomers", "Customer")',
                 method:'POST',
                 data:parameter,
                 dataType:'json',
                 success:function(result)
                 {
                     console.log(result);
                     toastMessage('success','Registro creado exitosamente');
                     clearFormCustomer();
                     getrAllCustomer();
                 },
                 error:function(error)
                 {
                     errorHttp(error);
                 }
             });
         }

         function editCustomer(id){
             isEdit=true;
             const customer=listCustomer.find(x=>x.customerId==id);
             $('#txtId').val(customer.customerId);
             $('#txtId').attr('disabled',true);
             $('#txtCompany').val(customer.companyName);
             $('#txtCountry').val(customer.country);
             $('#txtContactName').val(customer.contactName);
             $('#txtPhone').val(customer.phone);

             openModal(true);
         }

          function confirmEditCustomer(parameter){
              $.ajax({
                 url:'@Url.Action("UpdateCustomers", "Customer")',
                 method:'PUT',
                 data:parameter,
                 dataType:'json',
                 success:function(result)
                 {
                     console.log(result);
                     toastMessage('success','Registro actualizado exitosamente');
                     clearFormCustomer();
                     getrAllCustomer();
                 },
                 error:function(error)
                 {
                     errorHttp(error);
                 }
             });
         }

    </script>
}